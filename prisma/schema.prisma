// ============================================================================
// LoLympic — Prisma Schema (Step 1)
// AI-powered global meme translation + Olympic-style country competition
// Stack: Next.js + Prisma + PostgreSQL
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum LanguageCode {
  ko
  en
  ja
  zh
  es
  hi
  ar
}

enum PostStatus {
  DRAFT
  PROCESSING    // AI translation in progress
  PUBLISHED
  HIDDEN
  UNDER_REVIEW  // Flagged by content moderation
  REMOVED
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

// Using string field for PostCategory instead of enum.
// Meme categories evolve rapidly (e.g. trending formats, regional genres).
// A rigid enum would require schema migrations for every new category.
// Categories are managed via application logic / admin panel.

enum TranslationPayloadStatus {
  PENDING
  PROCESSING
  COMPLETED
  APPROVED
  REJECTED
  SUPERSEDED   // replaced by community-approved version
}

enum CreatorType {
  AI
  COMMUNITY
  ADMIN
}

enum SemanticRole {
  HEADLINE
  CAPTION
  DIALOGUE
  LABEL
  WATERMARK
  SUBTITLE
  OVERLAY
  OTHER
}

enum TextAlign {
  LEFT
  CENTER
  RIGHT
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  REMOVED
}

enum SuggestionType {
  TRANSLATION
  CULTURE_NOTE
}

enum SuggestionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUPERSEDED
}

enum TargetEntityType {
  TRANSLATION_PAYLOAD
  TRANSLATION_SEGMENT
  CULTURE_NOTE
}

enum ReactionType {
  FIRE
  LAUGH
  SKULL
  HEART
  CRY
}

enum SeasonStatus {
  UPCOMING
  ACTIVE
  JUDGING
  COMPLETED
  ARCHIVED
}

enum SeasonEntryStatus {
  SUBMITTED
  QUALIFIED
  DISQUALIFIED
  WITHDRAWN
}

enum MedalType {
  GOLD
  SILVER
  BRONZE
}

enum MedalScope {
  COUNTRY
  CREATOR
  MEME
  TRANSLATOR
  CULTURE_CONTRIBUTOR
  EDITOR
}

enum RewardType {
  PROFILE_BORDER
  PROFILE_TITLE
  BADGE
  FLAIR
  CUSTOM
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum NotificationType {
  REACTION
  COMMENT
  REPLY
  SUGGESTION
  SUGGESTION_APPROVED
  MEDAL_AWARDED
  REWARD_GRANTED
  FOLLOW
  SEASON_START
  SEASON_END
  SYSTEM
  DIRECT_MESSAGE
  FORWARD
  RANK_CHANGE
  TRANSLATION_REQUEST
  BATTLE_EVENT
  BADGE_EARNED
  STREAK_BONUS
  CHAMPIONSHIP_NOMINATED
  CHAMPIONSHIP_ELECTED
  CHAMPIONSHIP_VOTE_OPEN
  CHAMPIONSHIP_RESULT
}

enum CultureNoteStatus {
  DRAFT
  PUBLISHED
  APPROVED
  REJECTED
  SUPERSEDED
}

enum ChampionshipPhase {
  NOMINATION
  REPRESENTATIVE
  UPLOAD
  CHAMPIONSHIP
  COMPLETED
}

enum CandidateStatus {
  NOMINATED
  ELECTED
  RUNNER_UP
  SUBSTITUTE
  ELIMINATED
}

// ============================================================================
// CORE MODELS
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  emailVerified     DateTime?
  username          String   @unique
  displayName       String?
  avatarUrl         String?
  bio               String?
  passwordHash      String?
  countryId         String?
  preferredLanguage LanguageCode @default(en)
  uiLanguage        LanguageCode @default(en)
  role              UserRole     @default(USER)

  // Visible profile cosmetics (driven by rewards)
  profileTitle      String?
  profileBorder     String?
  activeRewardCode  String?

  // Level system
  totalXp           Int          @default(0)
  level             Int          @default(1)
  tier              String       @default("IRON")

  // Champion status (permanent gold border)
  isChampion        Boolean      @default(false)
  championSeasonId  String?      // Which season they won

  // Karma (community reputation, separate from XP)
  postKarma         Int          @default(0)
  commentKarma      Int          @default(0)

  // Ban/suspension
  isBanned          Boolean      @default(false)
  banReason         String?
  bannedAt          DateTime?
  bannedUntil       DateTime?    // null = permanent ban

  // Upload streak
  uploadStreakCount    Int       @default(0)
  uploadStreakLastDate DateTime?
  isCountryCaptain    Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts             Account[]
  country              Country?          @relation(fields: [countryId], references: [id])
  posts                Post[]
  comments             Comment[]
  suggestions          Suggestion[]
  suggestionVotes      SuggestionVote[]
  reactions            PostReaction[]
  savedPosts           PostSave[]
  followers            Follow[]          @relation("Following")
  following            Follow[]          @relation("Follower")
  blockedUsers         UserBlock[]       @relation("Blocker")
  blockedByUsers       UserBlock[]       @relation("Blocked")
  seasonEntries        SeasonEntry[]
  userSeasonStats      UserSeasonStat[]
  medals               Medal[]
  rewardGrants         RewardGrant[]
  reports              Report[]          @relation("Reporter")
  reportedByReports    Report[]          @relation("ReportedUser")
  notifications        Notification[]    @relation("Recipient")
  actedNotifications   Notification[]    @relation("Actor")
  translationPayloads  TranslationPayload[]
  cultureNotes         CultureNote[]
  conversationParticipants ConversationParticipant[]
  sentMessages         DirectMessage[]
  commentLikes         CommentLike[]
  monthlyWinners       MonthlyWinner[]
  finalVotes           FinalVote[]
  battles              Battle[]
  tournamentVotes      TournamentVote[]
  postVotes            PostVote[]
  adminAuditLogs       AdminAuditLog[]   @relation("AdminAuditLogs")
  badges               UserBadge[]
  countryBoardPosts    CountryBoard[]
  championshipCandidates    ChampionshipCandidate[]
  championshipVotes         ChampionshipVote[]       @relation("ChampionshipVoter")
  championshipPosts         ChampionshipPost[]       @relation("ChampionshipPostAuthor")
  championshipBattleVotes   ChampionshipBattleVote[] @relation("ChampionshipBattleVoter")
  passwordResetTokens       PasswordResetToken[]

  @@index([countryId])
}

model Country {
  id          String  @id // ISO 3166-1 alpha-2: "KR", "JP", "CN", "US", "MX"
  nameEn      String  // English name
  nameLocal   String  // Native name (e.g. 대한민국, 日本)
  flagEmoji   String  // 🇰🇷, 🇯🇵, etc.
  isActive    Boolean @default(true)
  themeColor  String? // Optional hex color for UI theming
  themeMeta   Json?   // Optional extended theme metadata

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users              User[]
  posts              Post[]
  seasonEntries      SeasonEntry[]
  countrySeasonStats CountrySeasonStat[]
  postSeasonStats    PostSeasonStat[]
  userSeasonStats    UserSeasonStat[]
  medals             Medal[]
  rewardGrants       RewardGrant[]
  monthlyWinners     MonthlyWinner[]
  vsEventsAsCountry1 CountryVsEvent[] @relation("VsEventCountry1")
  vsEventsAsCountry2 CountryVsEvent[] @relation("VsEventCountry2")
  countryBoardPosts  CountryBoard[]
  championshipCandidates ChampionshipCandidate[]
  championshipPosts      ChampionshipPost[]
}

model Post {
  id            String     @id @default(cuid())
  authorId      String
  countryId     String?
  seasonId      String?
  title         String
  body          String?
  category      String?    // Flexible string — see enum note above
  tags          String[]   @default([])
  sourceLanguage LanguageCode
  visibility    Visibility @default(PUBLIC)
  status        PostStatus @default(DRAFT)

  // Cached engagement counts (denormalized for performance)
  reactionCount    Int @default(0)
  commentCount     Int @default(0)
  shareCount       Int @default(0)
  saveCount        Int @default(0)
  viewCount        Int @default(0)
  translationCount Int @default(0)

  // Battle stats
  battleWins   Int @default(0)
  battleLosses Int @default(0)

  // Content moderation flag (set by AI safety check)
  moderationFlag String? // "SAFE" | "REVIEW" | "BLOCKED"

  // Vote score (upvotes - downvotes)
  voteScore    Int @default(0)

  // Cached ranking score (computed by ranking jobs)
  rankingScore Float @default(0)

  // Edit tracking
  isEdited    Boolean   @default(false)
  editedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  author              User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  country             Country?            @relation(fields: [countryId], references: [id], onDelete: SetNull)
  season              Season?             @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  images              PostImage[]
  translationPayloads TranslationPayload[]
  cultureNotes        CultureNote[]
  comments            Comment[]
  suggestions         Suggestion[]
  reactions           PostReaction[]
  saves               PostSave[]
  seasonEntries       SeasonEntry[]
  postSeasonStats     PostSeasonStat[]
  reports             Report[]
  notifications       Notification[]
  monthlyWinner       MonthlyWinner?
  battlesAsLeft       Battle[]           @relation("BattleLeft")
  battlesAsRight      Battle[]           @relation("BattleRight")
  votes               PostVote[]
  tournamentAsPost1   TournamentMatch[]  @relation("TournamentPost1")
  tournamentAsPost2   TournamentMatch[]  @relation("TournamentPost2")
  editHistory         PostEditHistory[]
  forwardedMessages   DirectMessage[]    @relation("ForwardedPost")
  championshipPost    ChampionshipPost?

  @@index([authorId])
  @@index([countryId])
  @@index([seasonId])
  @@index([status, visibility])
  @@index([status, visibility, authorId])
  @@index([rankingScore(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([category])
}

model PostImage {
  id              String @id @default(cuid())
  postId          String
  originalUrl     String // Original uploaded image
  cleanUrl        String? // Text-stripped clean version for re-rendering
  width           Int?
  height          Int?
  fileSizeBytes   Int?
  mimeType        String?
  altText         String?
  orderIndex      Int    @default(0)

  createdAt DateTime @default(now())

  // Relations
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model TranslationPayload {
  id               String                   @id @default(cuid())
  postId           String
  sourceLanguage   LanguageCode
  targetLanguage   LanguageCode
  version          Int                      @default(1)
  status           TranslationPayloadStatus @default(PENDING)
  confidence       Float?                   // AI confidence score 0.0–1.0
  memeType         String?                  // "A" (overlay), "B" (screenshot), "C" (multi-panel)
  translatedImageUrl String?                // Pre-rendered image with translated text burned in (first image)
  translatedImageUrls Json?                 // Multi-image: ["url0", "url1", "url2"] per imageIndex
  translatedTitle  String?                  // Translated post title
  translatedBody   String?                  // Translated post body
  creatorType      CreatorType              @default(AI)
  creatorId        String?                  // User who created (null if AI)
  approvedFromId   String?                  // Suggestion that replaced this payload

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post             Post                  @relation(fields: [postId], references: [id], onDelete: Cascade)
  creator          User?                 @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  approvedFrom     Suggestion?           @relation("ApprovedTranslation", fields: [approvedFromId], references: [id])
  segments         TranslationSegment[]

  @@unique([postId, targetLanguage, version])
  @@index([postId, targetLanguage])
  @@index([status])
  // Hot path for the worker's "count remaining PROCESSING payloads for this
  // post" query and for the enqueue route's latest-per-language lookup.
  @@index([postId, status])
  // Used by /api/admin/retranslate to bulk-delete by language.
  @@index([targetLanguage, status])
}

model TranslationSegment {
  id                  String       @id @default(cuid())
  translationPayloadId String
  orderIndex          Int
  imageIndex          Int          @default(0) // Which image in the post (0-based)

  // Text content
  sourceText          String
  translatedText      String
  semanticRole        SemanticRole @default(OTHER)

  // Absolute box coordinates for pixel-perfect rendering
  boxX                Float?
  boxY                Float?
  boxWidth            Float?
  boxHeight           Float?

  // Text style metadata
  fontFamily          String?
  fontWeight          Int?         // 100–900
  fontSizePixels      Float?
  lineHeightRatio     Float?       // e.g. 1.2
  letterSpacing       Float?
  color               String?      // hex color
  backgroundColor     String?      // hex color for text background

  // Alignment & transform
  textAlign           TextAlign    @default(CENTER)
  rotation            Float?       // degrees
  isUppercase         Boolean      @default(false)

  // Stroke / shadow for readability on images
  strokeColor         String?
  strokeWidth         Float?
  shadowColor         String?
  shadowOffsetX       Float?
  shadowOffsetY       Float?
  shadowBlur          Float?

  // Font hint for rendering engine
  fontHint            String?      // e.g. "impact", "noto-sans-kr", "ms-gothic"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  translationPayload TranslationPayload @relation(fields: [translationPayloadId], references: [id], onDelete: Cascade)

  @@index([translationPayloadId])
  @@index([orderIndex])
}

model CultureNote {
  id              String          @id @default(cuid())
  postId          String
  language        LanguageCode
  summary         String          // Short one-liner
  explanation     String          // Detailed cultural context
  translationNote String?         // How this affects translation choices
  creatorType     CreatorType     @default(AI)
  creatorId       String?
  status          CultureNoteStatus @default(DRAFT)
  confidence      Float?
  version         Int             @default(1)
  approvedFromId  String?         // Suggestion that replaced this note

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post         Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  creator      User?       @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  approvedFrom Suggestion? @relation("ApprovedCultureNote", fields: [approvedFromId], references: [id])

  @@unique([postId, language, version])
  @@index([postId, language])
  @@index([status])
}

// ============================================================================
// COMMUNITY MODELS
// ============================================================================

model Comment {
  id        String        @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?       // 2-depth reply support
  body      String
  language  LanguageCode?
  status    CommentStatus @default(VISIBLE)
  isPinned  Boolean       @default(false)
  isEdited  Boolean       @default(false)

  // Cached counts
  replyCount Int @default(0)
  likeCount  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]     @relation("CommentReplies")
  likes         CommentLike[]
  reports       Report[]
  notifications Notification[]

  @@index([postId, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([parentId])
  @@index([postId, authorId])
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
}

model Suggestion {
  id               String           @id @default(cuid())
  postId           String
  authorId         String
  type             SuggestionType
  targetLanguage   LanguageCode?
  targetEntityType TargetEntityType
  targetEntityId   String           // Polymorphic: ID of the target entity

  originalText     String
  proposedText     String
  reason           String?

  // Vote counts (denormalized)
  upvoteCount      Int              @default(0)
  downvoteCount    Int              @default(0)

  // Approval
  status           SuggestionStatus @default(PENDING)
  reviewedBy       String?
  reviewedAt       DateTime?
  reviewNote       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  post                       Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  author                     User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes                      SuggestionVote[]
  approvedTranslationPayloads TranslationPayload[] @relation("ApprovedTranslation")
  approvedCultureNotes       CultureNote[]        @relation("ApprovedCultureNote")
  reports                    Report[]
  notifications              Notification[]

  @@index([postId, type])
  @@index([authorId])
  @@index([targetEntityType, targetEntityId])
  @@index([status])
}

model SuggestionVote {
  id           String   @id @default(cuid())
  suggestionId String
  userId       String
  isUpvote     Boolean

  createdAt DateTime @default(now())

  // Relations
  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@index([userId])
}

model PostReaction {
  id       String       @id @default(cuid())
  postId   String
  userId   String
  type     ReactionType @default(FIRE)

  createdAt DateTime @default(now())

  // Relations
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
}

model PostVote {
  id     String @id @default(cuid())
  postId String
  userId String
  value  Int    // 1 = upvote, -1 = downvote

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostSave {
  id     String @id @default(cuid())
  postId String
  userId String

  createdAt DateTime @default(now())

  // Relations
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String

  createdAt DateTime @default(now())

  // Relations
  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model PostEditHistory {
  id       String   @id @default(cuid())
  postId   String
  field    String   // "title", "body", "tags", "category"
  oldValue String?
  newValue String?
  editedAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, editedAt(sort: Desc)])
}

// ============================================================================
// COMPETITION MODELS
// ============================================================================

model Season {
  id          String       @id @default(cuid())
  name        String       // e.g. "Season 1 — Meme World Cup"
  number      Int          @unique
  status      SeasonStatus @default(UPCOMING)
  description String?
  startAt     DateTime
  endAt       DateTime

  // Champion info (set when season is COMPLETED)
  championPostId    String?   // Winning meme
  championUserId    String?   // Winner user
  championCountryId String?   // Winning country
  votingStartAt     DateTime? // Final vote start (e.g. Dec 15)
  votingEndAt       DateTime? // Final vote end (e.g. Dec 31)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  posts              Post[]
  entries            SeasonEntry[]
  countrySeasonStats CountrySeasonStat[]
  postSeasonStats    PostSeasonStat[]
  userSeasonStats    UserSeasonStat[]
  medals             Medal[]
  rewardGrants       RewardGrant[]
  monthlyWinners     MonthlyWinner[]
  finalVotes         FinalVote[]
  tournamentMatches  TournamentMatch[]
  championship       Championship?
}

model SeasonEntry {
  id        String            @id @default(cuid())
  seasonId  String
  postId    String
  authorId  String
  countryId String?
  status    SeasonEntryStatus @default(SUBMITTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  season  Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([seasonId, postId])
  @@index([seasonId, countryId])
  @@index([authorId])
}

model CountrySeasonStat {
  id        String    @id @default(cuid())
  seasonId  String
  countryId String
  rank      Int?
  medal     MedalType?

  // Aggregate scores
  totalScore       Float @default(0)
  totalPosts       Int   @default(0)
  totalCreators    Int   @default(0)
  totalReactions   Int   @default(0)
  totalShares      Int   @default(0)
  totalTranslationViews Int @default(0)

  computedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  season  Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([seasonId, countryId])
}

model PostSeasonStat {
  id         String    @id @default(cuid())
  seasonId   String
  postId     String
  countryId  String?

  globalRank  Int?
  countryRank Int?
  medal       MedalType?

  // Scoring
  totalScore         Float @default(0)
  reactionScore      Float @default(0)
  commentScore       Float @default(0)
  shareScore         Float @default(0)
  translationScore   Float @default(0)
  cultureScore       Float @default(0)
  decayAdjustedScore Float @default(0)

  computedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  season  Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([seasonId, postId])
  @@index([seasonId, globalRank])
  @@index([seasonId, countryId, countryRank])
}

model UserSeasonStat {
  id        String    @id @default(cuid())
  seasonId  String
  userId    String
  countryId String?

  globalRank  Int?
  countryRank Int?
  medal       MedalType?

  // Aggregate scores
  totalScore                Float @default(0)
  totalPosts                Int   @default(0)
  totalApprovedSuggestions  Int   @default(0)
  totalCultureContributions Int   @default(0)

  computedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  season  Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([seasonId, globalRank])
  @@index([seasonId, countryId, countryRank])
}

model Medal {
  id          String     @id @default(cuid())
  seasonId    String
  type        MedalType
  scope       MedalScope
  label       String     // e.g. "Best Meme — Gold"
  description String?

  // Nullable links depending on scope
  userId    String?
  countryId String?
  postId    String?

  createdAt DateTime @default(now())

  // Relations
  season  Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryId], references: [id], onDelete: Cascade)

  // Medal → RewardGrant
  rewardGrants RewardGrant[]

  @@index([seasonId, scope])
  @@index([userId])
  @@index([countryId])
}

model Reward {
  id          String     @id @default(cuid())
  code        String     @unique // e.g. "gold-border-s1", "champion-title"
  name        String
  description String?
  type        RewardType
  config      Json?      // Type-specific config (border style, title text, badge URL, etc.)
  isActive    Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  grants RewardGrant[]
}

model RewardGrant {
  id         String   @id @default(cuid())
  rewardId   String
  userId     String?
  countryId  String?
  seasonId   String?
  medalId    String?  // Source medal that triggered this grant

  validFrom  DateTime @default(now())
  validUntil DateTime?
  metadata   Json?    // Extra context

  createdAt DateTime @default(now())

  // Relations
  reward  Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)
  season  Season?  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  medal   Medal?   @relation(fields: [medalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([rewardId])
  @@index([seasonId])
}

// ============================================================================
// MONTHLY WINNER & FINAL VOTE
// ============================================================================

model MonthlyWinner {
  id        String   @id @default(cuid())
  seasonId  String
  month     Int      // 1-12
  year      Int
  postId    String   @unique
  authorId  String?
  countryId String?
  likeCount Int      @default(0)

  createdAt DateTime @default(now())

  // Relations
  season     Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  post       Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  country    Country?  @relation(fields: [countryId], references: [id], onDelete: SetNull)
  finalVotes FinalVote[]

  @@unique([seasonId, month])
  @@index([seasonId])
  @@index([authorId])
  @@index([countryId])
}

model FinalVote {
  id              String   @id @default(cuid())
  seasonId        String
  monthlyWinnerId String
  userId          String
  createdAt       DateTime @default(now())

  // Relations
  season        Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  monthlyWinner MonthlyWinner @relation(fields: [monthlyWinnerId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId]) // One vote per user per season
  @@index([monthlyWinnerId])
}

// ============================================================================
// YEAR-END TOURNAMENT (Dec 29-31)
// ============================================================================

model TournamentMatch {
  id          String   @id @default(cuid())
  seasonId    String
  round       Int      // 1=quarterfinal(12/29), 2=semifinal(12/30), 3=final(12/31)
  matchIndex  Int      // match number within round (0-based)

  post1Id     String?
  post2Id     String?
  winnerId    String?  // set when voting ends

  post1Votes  Int      @default(0)
  post2Votes  Int      @default(0)

  startAt     DateTime
  endAt       DateTime

  createdAt   DateTime @default(now())

  // Relations
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  post1  Post?  @relation("TournamentPost1", fields: [post1Id], references: [id], onDelete: SetNull)
  post2  Post?  @relation("TournamentPost2", fields: [post2Id], references: [id], onDelete: SetNull)
  votes  TournamentVote[]

  @@unique([seasonId, round, matchIndex])
  @@index([seasonId, round])
}

model TournamentVote {
  id        String   @id @default(cuid())
  matchId   String
  userId    String
  postId    String   // which post they voted for

  createdAt DateTime @default(now())

  match TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId]) // one vote per match
  @@index([matchId])
}

// ============================================================================
// BATTLE MODELS
// ============================================================================

model Battle {
  id           String   @id @default(cuid())
  leftPostId   String
  rightPostId  String
  voterId      String
  chosenPostId String

  createdAt    DateTime @default(now())

  leftPost     Post     @relation("BattleLeft", fields: [leftPostId], references: [id], onDelete: Cascade)
  rightPost    Post     @relation("BattleRight", fields: [rightPostId], references: [id], onDelete: Cascade)
  voter        User     @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@index([voterId, createdAt(sort: Desc)])
  @@index([chosenPostId])
}

// ============================================================================
// OPS / SUPPORT MODELS
// ============================================================================

model Report {
  id            String       @id @default(cuid())
  reporterId    String?
  postId        String?
  commentId     String?
  targetUserId  String?
  suggestionId  String?
  reason        String
  detail        String?
  status        ReportStatus @default(PENDING)

  resolvedBy    String?
  resolvedAt    DateTime?
  resolutionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  reporter   User?       @relation("Reporter", fields: [reporterId], references: [id], onDelete: SetNull)
  post       Post?       @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment    Comment?    @relation(fields: [commentId], references: [id], onDelete: SetNull)
  suggestion Suggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)
  targetUser User? @relation("ReportedUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([status])
  @@index([postId])
  @@index([targetUserId])
}

model Notification {
  id           String           @id @default(cuid())
  recipientId  String
  actorId      String?
  postId       String?
  commentId    String?
  suggestionId String?
  type         NotificationType
  metadata     Json?            // Flexible extra context
  isRead       Boolean          @default(false)

  createdAt DateTime @default(now())

  // Relations
  recipient  User        @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor      User?       @relation("Actor", fields: [actorId], references: [id], onDelete: SetNull)
  post       Post?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment    Comment?    @relation(fields: [commentId], references: [id], onDelete: SetNull)
  suggestion Suggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([postId])
  @@index([commentId])
}

// ============================================================================
// DIRECT MESSAGING
// ============================================================================

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     DirectMessage[]
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model DirectMessage {
  id              String   @id @default(cuid())
  conversationId  String
  senderId        String
  body            String
  imageUrl        String?
  imageWidth      Int?
  imageHeight     Int?
  forwardedPostId String?
  createdAt       DateTime @default(now())

  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  forwardedPost Post?        @relation("ForwardedPost", fields: [forwardedPostId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@index([forwardedPostId])
}

// ============================================================================
// PASSWORD RESET TOKENS
// ============================================================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // "BAN_USER", "UNBAN_USER", "DELETE_POST", etc.
  targetId   String   // userId, postId, etc.
  targetType String   // "USER", "POST", "COMMENT"
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetId, targetType])
  @@index([createdAt])
}

// ============================================================================
// BADGES, STREAKS, VS EVENTS, COUNTRY BOARD
// ============================================================================

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeKey  String
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, badgeKey])
  @@index([userId])
}

model CountryVsEvent {
  id            String   @id @default(cuid())
  title         String
  country1Id    String
  country2Id    String
  startAt       DateTime
  endAt         DateTime
  status        String   @default("UPCOMING")
  country1Score Float    @default(0)
  country2Score Float    @default(0)
  winnerId      String?
  createdById   String
  createdAt     DateTime @default(now())
  country1      Country  @relation("VsEventCountry1", fields: [country1Id], references: [id], onDelete: Cascade)
  country2      Country  @relation("VsEventCountry2", fields: [country2Id], references: [id], onDelete: Cascade)
  @@index([status])
  @@index([startAt])
}

model CountryBoard {
  id        String   @id @default(cuid())
  countryId String
  authorId  String
  body      String   @db.Text
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  @@index([countryId, createdAt(sort: Desc)])
  @@index([authorId])
}

// ============================================================================
// YEAR-END CHAMPIONSHIP (Dec 1-31)
// ============================================================================

model Championship {
  id        String            @id @default(cuid())
  seasonId  String            @unique
  year      Int               @unique
  phase     ChampionshipPhase @default(NOMINATION)

  nominationStartAt     DateTime
  nominationEndAt       DateTime
  representativeStartAt DateTime
  representativeEndAt   DateTime
  uploadStartAt         DateTime
  uploadEndAt           DateTime
  battleStartAt         DateTime
  battleEndAt           DateTime
  resultAt              DateTime

  championUserId    String?
  championCountryId String?
  championPostId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season     Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  candidates ChampionshipCandidate[]
  votes      ChampionshipVote[]
  posts      ChampionshipPost[]

  @@index([year])
}

model ChampionshipCandidate {
  id               String          @id @default(cuid())
  championshipId   String
  userId           String
  countryId        String
  rank             Int
  status           CandidateStatus @default(NOMINATED)
  seasonScore      Float           @default(0)
  voteCount        Int             @default(0)
  weightedVoteScore Float          @default(0)
  autoElected      Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  country      Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)
  votes        ChampionshipVote[]

  @@unique([championshipId, userId])
  @@unique([championshipId, countryId, rank])
  @@index([championshipId, countryId])
  @@index([status])
}

model ChampionshipVote {
  id              String   @id @default(cuid())
  championshipId  String
  voterId         String
  candidateId     String
  voterCountryId  String?

  createdAt DateTime @default(now())

  championship Championship          @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  voter        User                   @relation("ChampionshipVoter", fields: [voterId], references: [id], onDelete: Cascade)
  candidate    ChampionshipCandidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([championshipId, voterId, candidateId])
  @@index([championshipId, candidateId])
  @@index([voterId])
}

model ChampionshipPost {
  id              String   @id @default(cuid())
  championshipId  String
  postId          String   @unique
  userId          String
  countryId       String

  battleVoteCount Int      @default(0)
  finalRank       Int?

  createdAt DateTime @default(now())

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  post         Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User         @relation("ChampionshipPostAuthor", fields: [userId], references: [id], onDelete: Cascade)
  country      Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)
  battleVotes  ChampionshipBattleVote[]

  @@unique([championshipId, countryId])
  @@index([championshipId])
}

model ChampionshipBattleVote {
  id                   String   @id @default(cuid())
  championshipPostId   String
  voterId              String

  createdAt DateTime @default(now())

  championshipPost ChampionshipPost @relation(fields: [championshipPostId], references: [id], onDelete: Cascade)
  voter            User             @relation("ChampionshipBattleVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([championshipPostId, voterId])
  @@index([championshipPostId])
  @@index([voterId])
}

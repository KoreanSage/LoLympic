# ═══════════════════════════════════════════════
# LoLympic - Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in the values.

# ─── Database (PostgreSQL / Neon) ────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth ────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Set to your production domain (Vercel sets this automatically)
# NEXTAUTH_URL="https://your-domain.com"

# ─── Google OAuth ────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI Translation (Google Gemini) ──────────
GEMINI_API_KEY="your-gemini-api-key"

# ─── File Storage (Cloudflare R2) ────────────
# All production uploads go to R2. Set all four values.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ─── App Config ──────────────────────────────
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_NAME="LoLympic"

# ─── Vercel Cron Jobs ────────────────────────
# Secret for authenticating cron job requests
# Generate: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here"

# ─── Upstash QStash (Async Translation Queue) ───
# Used by /api/translate/enqueue and /api/translate/worker for background
# image translation. When unset, enable NEXT_PUBLIC_TRANSLATE_ASYNC="false"
# to fall back to the legacy sync translation path.
QSTASH_TOKEN="your-qstash-token"
QSTASH_CURRENT_SIGNING_KEY="your-qstash-current-signing-key"
QSTASH_NEXT_SIGNING_KEY="your-qstash-next-signing-key"
# Public URL of the worker endpoint — QStash must be able to reach this.
# Example: https://mimzy.gg/api/translate/worker
QSTASH_WORKER_URL="https://your-domain.com/api/translate/worker"

# Feature flag: set to "true" to route uploads through the async queue.
NEXT_PUBLIC_TRANSLATE_ASYNC="false"

# ─── Local Development Only ──────────────────
# Used when R2 env vars are not set
UPLOAD_DIR="./uploads"
